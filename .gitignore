int inputPort=A0;
int outerPort=3;
void setup(){
  Serial.begin(9600);
  pinMode(inputPort,INPUT);
  //myservo.attach(outerPort);
  pinMode(outerPort,OUTPUT);
}
void loop(){
  int val=analogRead(inputPort);
  Serial.println(val);
  val=map(val,0,1023,0,255);
  analogWrite(outerPort,val);
  delay(50);}
